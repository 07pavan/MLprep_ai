# ── LLM API Keys ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ── Multi-Model Router ────────────────────────────────────────
# Tiers: "fast" (intent/summaries), "smart" (complex reasoning/code gen)
FAST_MODEL=gemini-1.5-flash
FAST_PROVIDER=google
SMART_MODEL=llama-3.3-70b-versatile
SMART_PROVIDER=groq
TEMPERATURE=0.1
LLM_TIMEOUT=30

# ── Storage Configuration ─────────────────────────────────────
# Relative or absolute path to persistent disk storage for dataset parquet files
STORAGE_DIR=storage
MAX_FILE_SIZE_MB=100

# ── CORS Settings (Comma-separated list of frontends) ───────
# Keep localhost origins for local dev, add your domain in production
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173"]

# ── Database & Postgres State Checkpointer (Production) ─────
# Uncomment and configure these when moving away from in-memory MemorySaver
# DATABASE_URL=postgresql://postgres_user:postgres_pass@postgres_host:5432/analyst_db
